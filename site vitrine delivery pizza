<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Delivery Pizza - Maubeuge | Pizzas Artisanales, Pâtes & Salades fraîches</title>
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700;800&display=swap" rel="stylesheet">
    
    <style>
        /* --- VARIABLES & RESET --- */
        :root {
            --red: #e31e24; /* Rouge du Logo */
            --blue: #0056b3; /* Bleu du Logo */
            --dark: #1a1a1a;
            --white: #ffffff;
            --light-gray: #f8f9fa;
            --shadow: 0 4px 15px rgba(0,0,0,0.08);
            --transition: all 0.3s ease;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Poppins', sans-serif; line-height: 1.6; color: var(--dark); scroll-behavior: smooth; background-color: var(--white); }
        a { text-decoration: none; color: inherit; transition: var(--transition); }
        ul { list-style: none; }

        /* --- NAVIGATION (Mobile First) --- */
        nav {
            background: var(--white);
            padding: 1rem 5%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: fixed;
            width: 100%;
            top: 0;
            z-index: 1000;
            box-shadow: var(--shadow);
        }
        .logo { font-weight: 800; font-size: 1.6rem; color: var(--red); display: flex; align-items: center; }
        .logo span { color: var(--blue); margin-left: 4px; }
        
        .nav-links { display: none; } /* Caché sur mobile par défaut */
        
        .btn-call-nav {
            background: var(--red);
            color: white;
            padding: 10px 20px;
            border-radius: 50px;
            font-weight: 700;
            font-size: 0.9rem;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .btn-call-nav:hover { transform: translateY(-2px); box-shadow: 0 4px 10px rgba(227,30,36,0.3); }

        /* --- HERO SECTION --- */
        .hero {
            height: 90vh;
            /* IMAGE DE FOND : Utilisation d'une image pro de remplacement de haute qualité */
            background: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.5)), url('https://images.unsplash.com/photo-1593560704563-f176a2eb61db?q=80&w=1920&auto=format&fit=crop');
            background-size: cover;
            background-position: center;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            color: var(--white);
            padding: 100px 5% 0;
        }
        .hero h1 { font-size: 3.8rem; font-weight: 800; line-height: 1.1; margin-bottom: 1rem; text-transform: uppercase; letter-spacing: -1px; }
        .hero p { font-size: 1.4rem; font-weight: 300; margin-bottom: 2.5rem; max-width: 700px; }
        .hero-btns { display: flex; gap: 20px; flex-wrap: wrap; justify-content: center; }
        
        .btn-main {
            padding: 18px 40px;
            border-radius: 50px;
            font-weight: 700;
            font-size: 1.1rem;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .btn-red { background: var(--red); color: white; }
        .btn-red:hover { background: #b31419; transform: scale(1.03); }
        .btn-blue { background: var(--blue); color: white; }
        .btn-blue:hover { background: #004494; transform: scale(1.03); }

        /* --- SECTION COMMUNE --- */
        .container { padding: 80px 5%; max-width: 1400px; margin: 0 auto; }
        .section-title { text-align: center; margin-bottom: 60px; }
        .section-title h2 { font-size: 3rem; font-weight: 800; color: var(--blue); text-transform: uppercase; letter-spacing: -1px; position: relative; display: inline-block; }
        .section-title h2::after { content: ''; width: 80px; height: 6px; background: var(--red); position: absolute; bottom: -15px; left: 50%; transform: translateX(-50%); border-radius: 3px; }
        .section-subtitle { font-size: 1.2rem; color: #666; margin-top: 25px; font-weight: 300; }

        /* --- MENU GRID --- */
        .menu-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 30px;
        }
        .menu-card {
            background: var(--white);
            padding: 30px;
            border-radius: 20px;
            border: 1px solid #eee;
            transition: var(--transition);
            position: relative;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }
        .menu-card:hover { transform: translateY(-8px); box-shadow: 0 15px 40px rgba(0,0,0,0.06); border-color: transparent; }
        .card-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 15px; }
        .card-header h3 { font-size: 1.5rem; font-weight: 700; color: var(--dark); }
        .card-price { color: var(--red); font-weight: 800; font-size: 1.3rem; background: rgba(227,30,36,0.05); padding: 5px 15px; border-radius: 50px; }
        
        .card-ingredients { font-size: 1rem; color: #555; font-weight: 300; margin-bottom: 20px; flex-grow: 1; }
        .card-icons { display: flex; gap: 10px; color: #bbb; font-size: 0.9rem; border-top: 1px solid #eee; padding-top: 15px; }
        .card-icons i { color: var(--red); opacity: 0.6; }

        /* --- BADGES --- */
        .badge { position: absolute; top: -12px; right: 20px; background: var(--blue); color: white; padding: 6px 15px; border-radius: 50px; font-size: 0.8rem; font-weight: 700; text-transform: uppercase; box-shadow: 0 4px 10px rgba(0,86,179,0.3); }
        .badge-creme { background: #fdfae6; color: #b38f00; border: 1px solid #ffeeba; }

        /* --- TABS NAV (Pour Pâtes/Salades) --- */
        .tabs-nav { display: flex; justify-content: center; gap: 15px; margin-bottom: 50px; flex-wrap: wrap; }
        .tab-btn { background: #eee; color: #555; padding: 12px 30px; border-radius: 50px; font-weight: 600; cursor: pointer; transition: var(--transition); border: none; font-size: 1rem; }
        .tab-btn.active { background: var(--blue); color: white; }

        /* --- OFFRES SPECIALES --- */
        .specials { background: var(--dark); color: white; border-radius: 30px; padding: 60px 5%; margin: 80px 0; display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 40px; align-items: center; position: relative; overflow: hidden; }
        .specials::before { content: ''; position: absolute; top: -50px; left: -50px; width: 200px; height: 200px; background: rgba(227,30,36,0.1); border-radius: 50%; }
        
        .promo-card { text-align: center; padding: 20px; position: relative; z-index: 1; }
        .promo-title { color: #ffce00; font-size: 2.5rem; font-weight: 800; text-transform: uppercase; letter-spacing: -1px; margin-bottom: 10px; }
        .promo-card h4 { font-size: 1.3rem; font-weight: 600; margin-bottom: 20px; opacity: 0.9; }
        .promo-card p { font-size: 1.1rem; font-weight: 300; margin-bottom: 30px; opacity: 0.8; }
        .promo-price { font-size: 4rem; font-weight: 800; color: var(--red); line-height: 1; margin-bottom: 10px; }
        .promo-card .btn-main { display: inline-flex; margin-top: 20px; }

        /* --- FOOTER --- */
        footer { background: #111; color: rgba(255,255,255,0.7); padding: 80px 5% 30px; margin-top: 80px; }
        .footer-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 50px; max-width: 1400px; margin: 0 auto; }
        .footer-logo { font-size: 2rem; color: var(--red); font-weight: 800; margin-bottom: 15px; }
        .footer-logo span { color: var(--blue); }
        .footer-col h4 { color: var(--white); font-weight: 700; margin-bottom: 25px; text-transform: uppercase; font-size: 1.1rem; letter-spacing: 1px; }
        .footer-col p { margin-bottom: 15px; display: flex; align-items: flex-start; gap: 12px; }
        .footer-col i { color: var(--red); margin-top: 4px; font-size: 1.1rem; }
        
        .hours-list li { display: flex; justify-content: space-between; margin-bottom: 10px; padding-bottom: 10px; border-bottom: 1px solid #222; }
        .hours-list .day { font-weight: 600; color: var(--white); }

        .footer-bottom { text-align: center; margin-top: 60px; border-top: 1px solid #222; padding-top: 30px; font-size: 0.9rem; }
        .footer-bottom a { color: var(--white); font-weight: 600; }

        /* --- RESPONSIVE ADAPTATIONS --- */
        @media (min-width: 992px) {
            nav { padding: 1rem 8%; }
            .nav-links { display: flex; }
            .nav-links li { margin-left: 30px; }
            .nav-links a { font-weight: 600; font-size: 1rem; color: var(--dark); }
            .nav-links a:hover { color: var(--red); }
            .container { padding: 100px 8%; }
            .hero h1 { font-size: 4.8rem; }
        }

        @media (max-width: 768px) {
            .hero h1 { font-size: 2.8rem; }
            .hero p { font-size: 1.1rem; }
            .section-title h2 { font-size: 2.2rem; }
            .btn-main { padding: 15px 30px; font-size: 1rem; }
            .specials { padding: 40px 5%; }
            .promo-price { font-size: 3rem; }
        }
    </style>
</head>
